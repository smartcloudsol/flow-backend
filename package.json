    "@aws-sdk/client-kms": "^3.987.0",
    "@aws-sdk/client-route-53": "^3.1015.0",
    "@aws-sdk/client-s3": "^3.987.0",
    "@aws-sdk/client-sesv2": "^3.987.0",
    "@aws-sdk/client-sqs": "^3.987.0",
